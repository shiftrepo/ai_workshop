{
  "_comment": "auto-repair-demo 専用の設定。親 Claude Code セッションの CLAUDE_EFFORT からは独立して動作する。デモの応答速度・SSHログ収集先をここだけで調整できる。",
  "model": "us.anthropic.claude-sonnet-5",
  "defaultEffort": "low",
  "agents": {
    "incident-analyzer": { "effort": "low",  "timeoutMs": 180000 },
    "repair-planner":     { "effort": "low",  "timeoutMs": 180000 },
    "pr-publisher":       { "effort": "low",  "timeoutMs": 600000 }
  },
  "_logCollectorComment": "log_collector が SSH でログを引く先。dev-environment/docker の3サーバ (localhost:5001-5003)。鍵はリポジトリルートからの相対パスで解決される。",
  "logCollector": {
    "sshKeyPath": "projects/log_collector/dev-environment/sample-data/log_collector_key",
    "sshUser": "logcollector",
    "servers": [
      { "host": "localhost", "port": "5001" },
      { "host": "localhost", "port": "5002" },
      { "host": "localhost", "port": "5003" }
    ]
  }
}
